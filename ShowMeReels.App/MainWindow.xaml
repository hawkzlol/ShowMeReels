<Window x:Class="ShowMeReels.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="ShowMeReels"
        Background="#0F1318"
        Icon="pack://application:,,,/Assets/Icon.png"
        MinHeight="640"
        MinWidth="360"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F2630" />
            <Setter Property="BorderBrush" Value="#293241" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#273140" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#313C4D" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1F2630" />
            <Setter Property="BorderBrush" Value="#293241" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#273140" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#313C4D" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#314154" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#50647D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowToggleButtonStyle" BasedOn="{StaticResource TopToggleButtonStyle}" TargetType="ToggleButton">
            <Setter Property="Height" Value="56" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#273140" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#313C4D" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#314154" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#50647D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LayoutButtonStyle" BasedOn="{StaticResource TopButtonStyle}" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>

        <Style x:Key="WindowButtonStyle" BasedOn="{StaticResource TopButtonStyle}" TargetType="Button">
            <Setter Property="Height" Value="56" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlatformSwitchToggleButtonStyle" BasedOn="{StaticResource WindowToggleButtonStyle}" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="0" />
        </Style>

    </Window.Resources>

    <Border Background="#10151C"
            BorderBrush="#202835"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarBorder"
                    Grid.Row="0"
                    Background="#161C25"
                    BorderBrush="#202835"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0">
                        <Button x:Name="LayoutButton"
                                Click="LayoutButton_Click"
                                Style="{StaticResource LayoutButtonStyle}"
                                ToolTip="Window position and size">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Snap to left edge"
                                              Click="SnapLeftButton_Click" />
                                    <MenuItem Header="Snap to left-center"
                                              Click="SnapLeftMiddleButton_Click" />
                                    <MenuItem Header="Snap to center"
                                              Click="SnapCenterButton_Click" />
                                    <MenuItem Header="Snap to right-center"
                                              Click="SnapRightMiddleButton_Click" />
                                    <MenuItem Header="Snap to right edge"
                                              Click="SnapRightButton_Click" />
                                    <Separator />
                                    <MenuItem Header="Reset default size"
                                              Click="ResetSizeButton_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="18"
                                         Height="18"
                                         Margin="0,0,8,0">
                                    <Grid Width="20" Height="20">
                                        <Border BorderBrush="#9FB0C6"
                                                BorderThickness="1.5"
                                                CornerRadius="2" />
                                        <Border Width="5"
                                                Height="14"
                                                Margin="3,3,0,3"
                                                HorizontalAlignment="Left"
                                                Background="#F5F7FA"
                                                CornerRadius="1" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock VerticalAlignment="Center"
                                           Text="Layout" />
                                <Path Width="8"
                                      Height="5"
                                      Margin="8,1,0,0"
                                      VerticalAlignment="Center"
                                      Data="M 0,0 L 4,5 L 8,0 Z"
                                      Fill="#9FB0C6"
                                      Stretch="Fill" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#F5F7FA"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="ShowMeReels" />

                    <Grid Grid.Column="2">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Stretch">
                            <ToggleButton x:Name="InstagramPlatformButton"
                                          Click="InstagramPlatformButton_Click"
                                          Style="{StaticResource PlatformSwitchToggleButtonStyle}"
                                          ToolTip="Open Instagram Reels">
                                <TextBlock Text="Instagram" />
                            </ToggleButton>
                            <ToggleButton x:Name="TikTokPlatformButton"
                                          Click="TikTokPlatformButton_Click"
                                          Style="{StaticResource PlatformSwitchToggleButtonStyle}"
                                          ToolTip="Open TikTok">
                                <TextBlock Text="TikTok" />
                            </ToggleButton>
                            <ToggleButton x:Name="PinButton"
                                          Click="PinButton_Click"
                                          Style="{StaticResource WindowToggleButtonStyle}"
                                          ToolTip="Keep window on top">
                                <Viewbox Width="18"
                                         Height="18">
                                    <Path Data="M 11.8,1.5 L 16.2,5.9 L 14.7,7.4 L 13.4,6.1 L 10.8,8.7 L 10.8,11.1 L 9.8,12.1 L 8.3,10.6 L 4.2,14.7 L 3.3,13.8 L 7.4,9.7 L 5.9,8.2 L 6.9,7.2 L 9.3,7.2 L 11.9,4.6 L 10.6,3.3 Z"
                                          Stretch="Uniform"
                                          Fill="#F5F7FA" />
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="ArrowCaptureButton"
                                          Click="ArrowCaptureButton_Click"
                                          Style="{StaticResource WindowToggleButtonStyle}"
                                          ToolTip="Capture global Up/Down keys while pinned">
                                <Viewbox Width="18"
                                         Height="18">
                                    <Path Data="M 9,1.4 L 14.2,6.6 L 12.8,8 L 10,5.2 L 10,16.6 L 8,16.6 L 8,5.2 L 5.2,8 L 3.8,6.6 Z M 9,16.6 L 14.2,11.4 L 12.8,10 L 10,12.8 L 10,1.4 L 8,1.4 L 8,12.8 L 5.2,10 L 3.8,11.4 Z"
                                          Stretch="Uniform"
                                          Fill="#F5F7FA" />
                                </Viewbox>
                            </ToggleButton>
                            <ToggleButton x:Name="SettingsButton"
                                          Click="SettingsButton_Click"
                                          PreviewMouseLeftButtonDown="SettingsButton_PreviewMouseLeftButtonDown"
                                          Style="{StaticResource WindowToggleButtonStyle}"
                                          ToolTip="Settings menu">
                                <Grid Width="20" Height="20">
                                    <Border Height="2"
                                            Margin="1,3,1,0"
                                            VerticalAlignment="Top"
                                            Background="#9FB0C6"
                                            CornerRadius="1" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Margin="2,1,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Fill="#F5F7FA"
                                             Stroke="#161C25"
                                             StrokeThickness="1.2" />

                                    <Border Height="2"
                                            Margin="1,0,1,0"
                                            VerticalAlignment="Center"
                                            Background="#9FB0C6"
                                            CornerRadius="1" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Margin="0,0,2,0"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Fill="#F5F7FA"
                                             Stroke="#161C25"
                                             StrokeThickness="1.2" />

                                    <Border Height="2"
                                            Margin="1,0,1,3"
                                            VerticalAlignment="Bottom"
                                            Background="#9FB0C6"
                                            CornerRadius="1" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Margin="6,0,0,1"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Bottom"
                                             Fill="#F5F7FA"
                                             Stroke="#161C25"
                                             StrokeThickness="1.2" />
                                </Grid>
                            </ToggleButton>
                            <Button Click="ReloadButton_Click"
                                    Style="{StaticResource WindowButtonStyle}"
                                    ToolTip="Reload current page">
                                <Viewbox Width="18"
                                         Height="18">
                                    <Path Data="M 9,1.5 A 6.5,6.5 0 1 0 15.1,5 H 12.7 A 4.6,4.6 0 1 1 9,4.4 V 1.5 Z M 8.2,0.9 L 12.4,0.9 L 12.4,5.1"
                                          Stretch="Uniform"
                                          Fill="#F5F7FA" />
                                </Viewbox>
                            </Button>
                            <Button Content="_"
                                    Click="MinimizeButton_Click"
                                    Style="{StaticResource WindowButtonStyle}"
                                    ToolTip="Minimize to taskbar" />
                            <Button Content="X"
                                    Click="CloseButton_Click"
                                    Style="{StaticResource WindowButtonStyle}"
                                    ToolTip="Hide to tray" />
                        </StackPanel>

                        <Popup x:Name="SettingsPopup"
                               AllowsTransparency="True"
                               Closed="SettingsPopup_Closed"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=SettingsButton}"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               VerticalOffset="8">
                            <Border x:Name="SettingsPopupBorder"
                                    Width="280"
                                    Background="#131A23"
                                    BorderBrush="#2A3342"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#F5F7FA"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Playback speed" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock x:Name="PlaybackSpeedValueText"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#9FB0C6"
                                                   Text="1x" />
                                        <Slider x:Name="PlaybackSpeedSlider"
                                                Minimum="0.25"
                                                Maximum="10"
                                                SmallChange="0.25"
                                                LargeChange="0.5"
                                                TickFrequency="0.25"
                                                ValueChanged="PlaybackSpeedSlider_ValueChanged" />
                                    </DockPanel>

                                    <TextBlock Margin="0,18,0,0"
                                               Foreground="#F5F7FA"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Volume" />
                                    <DockPanel Margin="0,8,0,0">
                                        <TextBlock x:Name="VolumeValueText"
                                                   DockPanel.Dock="Right"
                                                   Foreground="#9FB0C6"
                                                   Text="50%" />
                                        <Slider x:Name="VolumeSlider"
                                                Minimum="0"
                                                Maximum="100"
                                                SmallChange="1"
                                                LargeChange="5"
                                                TickFrequency="5"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="VolumeSlider_ValueChanged" />
                                    </DockPanel>

                                    <CheckBox x:Name="SeekBarCheckBox"
                                              Margin="0,18,0,0"
                                              Checked="SeekBarCheckBox_Changed"
                                              Foreground="#F5F7FA"
                                              Unchecked="SeekBarCheckBox_Changed">
                                        Seek bar
                                    </CheckBox>

                                    <CheckBox x:Name="BackgroundPlaybackCheckBox"
                                              Margin="0,12,0,0"
                                              Checked="BackgroundPlaybackCheckBox_Changed"
                                              Foreground="#F5F7FA"
                                              ToolTip="Keep audio and video playing while another app is focused."
                                              Unchecked="BackgroundPlaybackCheckBox_Changed">
                                        Background playback
                                    </CheckBox>

                                    <CheckBox x:Name="HardwareAccelerationCheckBox"
                                              Margin="0,12,0,0"
                                              Checked="HardwareAccelerationCheckBox_Changed"
                                              Foreground="#F5F7FA"
                                              Unchecked="HardwareAccelerationCheckBox_Changed">
                                        Hardware acceleration
                                    </CheckBox>

                                    <CheckBox x:Name="SkipSeenReelsCheckBox"
                                              Margin="0,12,0,0"
                                              Checked="SkipSeenReelsCheckBox_Changed"
                                              Foreground="#F5F7FA"
                                              Unchecked="SkipSeenReelsCheckBox_Changed">
                                        Skip seen videos this session
                                    </CheckBox>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="#0D1117">
                <wv2:WebView2 x:Name="ReelsWebView"
                              NavigationCompleted="ReelsWebView_NavigationCompleted" />
            </Grid>
        </Grid>
    </Border>
</Window>
